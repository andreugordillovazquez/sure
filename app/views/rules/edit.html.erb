<%= link_to t(".back_to_rules"), rules_path %>

<%= render DS::Dialog.new do |dialog| %>
  <%
    title = if @rule.name.present?
              t(".title_with_name", resource_type: @rule.resource_type, name: @rule.name)
            else
              t(".title", resource_type: @rule.resource_type)
            end
  %>
  <% dialog.with_header(title: title) %>

  <% dialog.with_body do %>
    <%= render "rules/form", rule: @rule %>
  <% end %>
<% end %>
